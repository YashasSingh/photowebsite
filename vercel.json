{
  "framework": "flask",
  "python": "3.11",
  "buildCommand": "pip install -r requirements.txt",
  "functions": {
    "api/index.py": {
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    }
  ]
}
